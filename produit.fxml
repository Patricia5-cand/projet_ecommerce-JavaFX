<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>

<VBox spacing="20" xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1" 
      fx:controller="controller.ProduitController" style="-fx-background-color: #f4f4f4;">
    
    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <Label text="Gestion des Produits" style="-fx-font-weight: bold;">
        <font>
            <Font size="24.0" />
        </font>
    </Label>

    <HBox spacing="15">
        <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 15; -fx-border-color: #ddd; -fx-border-radius: 5;">
            <Label text="Informations Produit" style="-fx-font-size: 16; -fx-text-fill: #555;"/>
            <TextField fx:id="txtNom" promptText="Nom du produit" />
            <TextField fx:id="txtPrix" promptText="Prix" />
            <TextField fx:id="txtQuantite" promptText="Quantité en stock" />
            
            <HBox spacing="10">
                <Button text="Ajouter" fx:id="btnAjouter" onAction="#handleAjouter" 
                        style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-cursor: hand;"/>
                <Button text="Modifier" fx:id="btnModifier" onAction="#handleModifier"
                        style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
                <Button text="Supprimer" fx:id="btnSupprimer" onAction="#handleSupprimer"
                        style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
            </HBox>
        </VBox>

        <TableView fx:id="tableProduits" HBox.hgrow="ALWAYS">
            <columns>
                <TableColumn fx:id="colId" text="ID" prefWidth="50" />
                <TableColumn fx:id="colNom" text="Nom" prefWidth="150" />
                <TableColumn fx:id="colPrix" text="Prix" prefWidth="100" />
                <TableColumn fx:id="colStock" text="Stock" prefWidth="100" />
            </columns>
        </TableView>
    </HBox>
</VBox>
